{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2023",
    "types": ["node", "mocha", "chai"],
    "typeRoots": ["node_modules/@types"],
    "lib": ["dom", "es2023"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/tools/**/*"]
}
